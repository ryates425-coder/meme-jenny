# Copy this file to .env and add your keys.

# Instant (database) - https://instantdb.com/dash
# Use VITE_ prefix for the React feed app (Vite)
VITE_INSTANT_APP_ID=2599b29a-21e9-4e11-91d3-b37ca19b5316
# NEXT_PUBLIC_ for Next.js if you migrate
# NEXT_PUBLIC_INSTANT_APP_ID=2599b29a-21e9-4e11-91d3-b37ca19b5316

# AI meme suggestions (https://console.anthropic.com/)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-haiku-4-5  # optional; Haiku is fastest, use claude-3-5-sonnet for higher quality

# Email (choose one option)
# Option A: Gmail - use an App Password from Google Account settings
# GMAIL_USER=your@gmail.com
# GMAIL_APP_PASSWORD=your-app-password

# Option B: Custom SMTP
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_SECURE=false
# MAIL_USER=user
# MAIL_PASS=password
# MAIL_FROM=noreply@example.com

# SMS/MMS (Twilio - https://www.twilio.com/)
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+15551234567

# For SMS on localhost: run "ngrok http 3000" and set:
# PUBLIC_URL=https://your-ngrok-url.ngrok.io
